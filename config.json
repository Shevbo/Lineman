  "dedup_cache": {
    "enabled": true,
    "ttl_secs": 30,
    "max_entries": 200,
    "window_secs": 60,
    "max_retries": 3,
    "alert_cooldown": 300
  },
  "circuit_breaker": {
    "enabled": true,
    "window_secs": 60,
    "max_calls": 100,
    "max_bytes_per_call": 8000000,
    "max_bytes_window": 40000000,
    "alert_cooldown_secs": 120
  },
  "reverse_proxy": {
    "upstreams": {
      "lm-studio": "http://127.0.0.1:1234",
      "ollama-hoster": "http://10.66.0.7:11434/v1",
      "deepseek": "https://api.deepseek.com",
      "google": "https://generativelanguage.googleapis.com"
