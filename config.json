{
  "services": [
    {
      "id": "lm-studio",
      "name": "LM Studio (hyperv via smain tunnel)",
      "type": "openai",
      "base_url": "http://127.0.0.1:1234",
      "health_endpoint": "/v1/models",
      "timeout": 30,
      "interval": 60,
      "proxy": false
    },
    {
      "id": "ollama-hoster",
      "name": "Ollama (hoster, CPU)",
      "type": "openai",
      "base_url": "http://10.66.0.7:11434",
      "health_endpoint": "/api/tags",
      "timeout": 10,
      "interval": 60,
      "proxy": false
    },
    {
      "id": "deepseek-flash",
      "name": "DeepSeek Flash",
      "type": "deepseek",
      "model": "deepseek-v4-flash",
      "base_url": "https://api.deepseek.com",
      "health_endpoint": "/v1/models",
      "api_key_env": "DEEPSEEK_API_KEY",
      "openclaw_config_path": "",
      "timeout": 15,
      "interval": 60,
      "proxy": true
    },
    {
      "id": "deepseek-pro",
      "name": "DeepSeek Pro",
      "type": "deepseek",
      "model": "deepseek-v4-pro",
      "base_url": "https://api.deepseek.com",
      "health_endpoint": "/v1/models",
      "api_key_env": "DEEPSEEK_API_KEY",
      "openclaw_config_path": "",
      "timeout": 15,
      "interval": 60,
      "proxy": true
    },
    {
      "id": "gemini-flash",
      "name": "Gemini Flash",
      "type": "gemini",
      "model": "gemini-2.5-flash",
      "base_url": "https://generativelanguage.googleapis.com",
      "health_endpoint": "/v1beta/models",
      "api_key_env": "GEMINI_API_KEY",
      "openclaw_config_path": "",
      "timeout": 15,
      "interval": 60,
      "proxy": true
    },
    {
      "id": "gemini-pro",
      "name": "Gemini Pro",
      "type": "gemini",
      "model": "gemini-3.1-pro-preview",
      "base_url": "https://generativelanguage.googleapis.com",
      "health_endpoint": "/v1beta/models",
      "api_key_env": "GEMINI_API_KEY",
      "openclaw_config_path": "",
      "timeout": 15,
      "interval": 60,
      "proxy": true
    },
    {
      "id": "google-drive",
      "name": "Google Drive",
      "type": "google_drive",
      "base_url": "https://www.googleapis.com",
      "health_endpoint": "/drive/v3/files",
      "timeout": 10,
      "interval": 120,
      "proxy": true
    },
    {
      "id": "google-gmail",
      "name": "Google Gmail",
      "type": "google_gmail",
      "base_url": "https://gmail.googleapis.com",
      "health_endpoint": "/gmail/v1/users/me/profile",
      "timeout": 10,
      "interval": 120,
      "proxy": true
    },
    {
      "id": "google-calendar",
      "name": "Google Calendar",
      "type": "google_calendar",
      "base_url": "https://www.googleapis.com",
      "health_endpoint": "/calendar/v3/calendars/primary",
      "timeout": 10,
      "interval": 120,
      "proxy": true
    },
    {
      "id": "telegram",
      "name": "Telegram API",
      "type": "telegram",
      "base_url": "https://api.telegram.org",
      "health_endpoint_prefix": "/bot",
      "api_key_env": "TELEGRAM_BOT_TOKEN",
      "openclaw_config_path": "",
      "timeout": 10,
      "interval": 60,
      "proxy": true,
      "use_proxy6": false
    }
  ],
  "routing": {
    "default": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash"
    },
    "think": {
      "provider": "deepseek",
      "model": "deepseek-v4-pro"
    },
    "background": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash"
    },
    "longContext": {
      "provider": "gemini",
      "model": "gemini-3.1-pro-preview"
    },
    "longContextThreshold": 60000,
    "webSearch": {
      "provider": "gemini",
      "model": "gemini-2.5-flash"
    },
    "local": {
      "provider": "lm-studio",
      "model": "google/gemma-4-e4b"
    },
    "batch": {
      "provider": "ollama-hoster",
      "model": "llama3.2:3b"
    }
  },
  "proxy_server": {
    "host": "0.0.0.0",
    "port": 9090,
    "max_connections": 100,
    "request_timeout": 120,
    "llm_queue": {
      "max_concurrent": 10,
      "queue_timeout_s": 60,
      "hosts": [
        "api.deepseek.com",
        "generativelanguage.googleapis.com"
      ],
      "providers": [
        "deepseek",
        "google"
      ]
    }
  },
  "analytics": {
    "claude_logs_path": "~/.claude/projects/",
    "enabled": true
  },
  "rtk": {
    "binary_path": "~/.local/bin/rtk",
    "enabled": true
  },
  "global": {
    "check_interval_fast": 60,
    "check_interval_slow": 120,
    "deep_probe_every_n": 5,
    "down_threshold": 3,
    "latency_multiplier": 2.0,
    "proxy_url": "${LINEMAN_IPROYAL_URL}",
    "gemini_cf_proxy_url": "https://gemini-proxy-worker.bshevelev75.workers.dev",
    "proxy6_url": "",
    "gateway_log_pattern": "/tmp/openclaw/openclaw-*.log",
    "google_drive_folder": "1_4Yk7kpSs8FTNxbP4w0V1o301Vqa6mRa",
    "report_time": "23:59",
    "state_file": "state.json",
    "metrics_file": "metrics.json"
  },
