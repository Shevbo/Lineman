  "routing": {
    "default": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash"
    },
    "think": {
      "provider": "deepseek",
      "model": "deepseek-v4-pro"
    },
    "background": {
      "provider": "deepseek",
      "model": "deepseek-v4-flash"
    },
    "longContext": {
      "provider": "gemini",
      "model": "gemini-3.1-pro-preview"
    },
    "longContextThreshold": 60000,
    "webSearch": {
      "provider": "gemini",
      "model": "gemini-2.5-flash"
    },
    "local": {
      "provider": "lm-studio",
      "model": "google/gemma-4-e4b"
    },
    "batch": {
      "provider": "ollama-hoster",
      "model": "llama3.2:3b"
    }
  },
  "proxy_server": {
    "host": "0.0.0.0",
    "port": 9090,
    "max_connections": 100,
    "request_timeout": 120,
    "llm_queue": {
      "max_concurrent": 10,
      "queue_timeout_s": 60,
      "hosts": [
        "api.deepseek.com",
        "generativelanguage.googleapis.com"
      ],
      "providers": [
        "deepseek",
        "google"
      ]
    }
  },
